{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/update-changelog.js",
            "if": "Bash(git commit*)",
            "statusMessage": "Updating CHANGELOG.md...",
            "async": true
          }
        ]
      }
    ]
  }
}
